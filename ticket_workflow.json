    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let kiText = $input.item.json.text;\nlet saubererText = kiText.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n  // Wir VERSUCHEN, den Text in JSON zu verwandeln\n  let echtesJson = JSON.parse(saubererText);\n  \n  // Wenn es klappt, fügen wir einen unsichtbaren Stempel \"is_error: false\" hinzu\n  echtesJson.is_error = false;\n  return { json: echtesJson };\n\n} catch (error) {\n  // FÄLLT DAS SYSTEM AUF DIE NASE, fangen wir den Absturz hier ab!\n  // Wir bauen ein künstliches Notfall-JSON für die Datenbank\n  return {\n    json: {\n      \"kategorie\": \"KI_FEHLER\",\n      \"prioritaet\": \"Hoch\",\n      \"extrahierte_daten\": { \"raw_text\": kiText },\n      \"vorgeschlagene_aktion\": \"Manuelle Überprüfung erforderlich! KI hat ungültiges Format geliefert.\",\n      \"begruendung\": error.message,\n      \"is_error\": true // Dieser Stempel löst gleich den Alarm aus\n    }\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
